// A simple test bench for the spring 26 EE287 project
// Reduced number of cases for gate level simulations
// This will be encrypted for much of the code...
`timescale 1ns/10ps

module tb();
reg Clk,Reset;
reg [7:0] Din;
reg TX_EN;
reg [9:0] Dout;

typedef struct {
  string name;
  int ixv;
  logic [9:0] rdm,rdp;
  int dchm,dchp;
} dstrx;

dstrx datarm[0:255];
dstrx conrm[0:11];

class pkt;
    int ckix;           // checking index
    reg [7:0] td[$];    // data
    dstrx tcd[$];       // coded data
endclass : pkt

int cur_disp;

pkt cpkt[$];



initial begin
    Clk=0;
    cur_disp=-1;
    TX_EN=0;
    Din=0;
    repeat(300_095) begin
        #5 Clk=0;
        #5 Clk=1;
    end
    $fatal("\n\n\nran out of clocks during the simulation\n\n");
end

initial begin
    Reset=1;
    repeat(3) @(posedge(Clk)) #1;
    Reset=0;
end

initial begin
    $dumpfile("gate_200_250.vcd");
    $dumplimit(200_000_000);
    $dumpvars(9,E1);
    $dumpoff();
    #200 $dumpon();
    #50 $dumpoff();
end

